<!DOCTYPE html>
<html lang="en">
<head>
   <%- include('partials/head') %>
   <title><%= blog.title %></title>
</head>
<body>
   <%- include('partials/nav') %>
   <div class="container mt-4">
      <div class="row">
         <div class="col-md-8 offset-md-2">
            <article class="blog-post">
               <% if (blog.coverImageURL) { %>
                  <img src="<%= blog.coverImageURL %>" class="img-fluid mb-3" alt="<%= blog.title %>">
               <% } %>
               <h1 class="mb-3"><%= blog.title %></h1>
               <div class="mb-4">
                  <small class="text-muted">
                     By <%= blog.createdBy.name || blog.createdBy.email %> on <%= new Date(blog.createdAt).toLocaleDateString() %>
                  </small>
               </div>
               <div class="blog-content">
                  <%= blog.body %>
               </div>
            </article>
         </div>
      </div>
   </div>
   <%- include('partials/script') %>
</body>
</html>